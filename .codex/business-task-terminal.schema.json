{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Bestar business task turn result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "task_id",
    "status",
    "summary",
    "changed_files",
    "tests",
    "remaining_work",
    "external_verification",
    "blockers",
    "next_action"
  ],
  "properties": {
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "CONTINUE",
        "DONE",
        "CODE_COMPLETE_EXTERNAL_VERIFICATION_PENDING",
        "BLOCKED"
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "changed_files": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "tests": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "remaining_work": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "external_verification": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "blockers": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "next_action": {
      "type": "string"
    }
  }
}

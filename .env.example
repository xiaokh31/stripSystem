# API
API_PORT=4000
WEB_PORT=3000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Web API routing
# Browser requests should stay same-origin for LAN devices.
NEXT_PUBLIC_API_BASE_URL=/api
# Next.js server-side rendering and local rewrites use this API base.
API_BASE_URL=http://127.0.0.1:4000/api
API_PROXY_BASE_URL=http://127.0.0.1:4000/api

# Database
DATABASE_URL=postgresql://user:pwd@localhost:5432/database_name

# Redis
REDIS_URL=redis://localhost:6379

# Storage
STORAGE_ROOT=./storage

# Auth
JWT_SECRET=change-this-in-local-env
JWT_EXPIRES_IN=7d

# Worker
WORKER_PYTHON_PATH=./apps/worker-python

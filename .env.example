# Local Docker Compose
HTTP_PORT=80
POSTGRES_USER=bestar
POSTGRES_PASSWORD=bestar_dev_password
POSTGRES_DB=bestar_unloading
POSTGRES_PORT=15432
REDIS_PORT=16379

# API
CORS_ORIGINS=http://localhost,http://127.0.0.1,http://localhost:3000,http://127.0.0.1:3000
TZ=America/Edmonton
OPERATIONAL_TIME_ZONE=America/Edmonton

# Web API routing
# Browser requests should stay same-origin for LAN devices.
NEXT_PUBLIC_API_BASE_URL=/api
NEXT_PUBLIC_OPERATIONAL_TIME_ZONE=America/Edmonton
# Next.js server-side rendering and local rewrites use the Docker network API base.
WEB_SERVER_API_BASE_URL=http://api:4000/api
WEB_API_PROXY_BASE_URL=http://api:4000/api

# Database
# Docker Compose builds the service DATABASE_URL from POSTGRES_* values.

# Redis
REDIS_URL=redis://redis:6379

# Storage
STORAGE_ROOT=/workspace/storage
HOST_STORAGE_ROOT=./storage

# Auth
# Replace before pilot or production use. Do not reuse this placeholder.
# Legacy/non-browser access JWTs are short-lived. Browser persistence is
# controlled independently by the opaque session settings below.
JWT_SECRET=replace-with-long-random-secret
JWT_EXPIRES_IN_SECONDS=900
# Browser access is short lived; the opaque server-side session remains
# configurable up to the product ceiling of 400 days.
BROWSER_ACCESS_TOKEN_EXPIRES_IN_SECONDS=900
BROWSER_SESSION_IDLE_EXPIRES_IN_SECONDS=34560000
BROWSER_SESSION_ABSOLUTE_EXPIRES_IN_SECONDS=34560000
AUTH_RATE_LIMIT_MAX=10
AUTH_RATE_LIMIT_WINDOW_SECONDS=60
AUTH_RATE_LIMIT_FAIL_CLOSED=false
NATIVE_ACCESS_TOKEN_EXPIRES_IN_SECONDS=900
NATIVE_SESSION_IDLE_EXPIRES_IN_SECONDS=34560000
NATIVE_SESSION_ABSOLUTE_EXPIRES_IN_SECONDS=157680000
NATIVE_REFRESH_RATE_LIMIT_MAX=10
NATIVE_REFRESH_RATE_LIMIT_WINDOW_SECONDS=60

# Public deployment (disabled for local/LAN operation).
# Public mode refuses to start unless PUBLIC_BASE_URL/CORS are HTTPS, cookies
# are Secure, JWT_SECRET is non-placeholder and >=32 characters, Redis is
# configured, and the trusted proxy mode plus CIDRs are explicit.
PUBLIC_DEPLOYMENT_ENABLED=false
PUBLIC_BASE_URL=https://warehouse.example.invalid
BROWSER_COOKIE_SECURE=false
TRUSTED_PROXY_MODE=none
TRUSTED_PROXY_CIDRS=

# Cloudflare named tunnel (PUBLIC-DEPLOY-02). Store the real remotely-managed
# tunnel token in this gitignored file; never put the token itself in .env,
# Compose command arguments, logs, screenshots, or HANDOFF.md.
CLOUDFLARE_TUNNEL_TOKEN_FILE=../../.secrets/cloudflare-tunnel-token

# Optional one-time first-admin seed variables.
# Prefer passing these only to the seed command instead of leaving passwords in .env.
# SEED_ADMIN_EMAIL=<admin-email>
# SEED_ADMIN_PASSWORD=<unique-strong-admin-password>
# SEED_ADMIN_NAME=Initial Administrator

# Worker
WORKER_PYTHON_DIR=/workspace/apps/worker-python
REPORT_TEMPLATE_PATH=/workspace/samples/templates/卸柜报告-En.xlsx

# Browser E2E tests. Create this account with SEED_ADMIN_* before running Playwright.
E2E_ADMIN_EMAIL=<e2e-admin-email>
E2E_ADMIN_PASSWORD=<e2e-admin-password>

<resources>
    <style name="AppTheme" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:fontFamily">sans</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>
        <item name="android:statusBarColor">@color/native_background</item>
        <item name="android:navigationBarColor">@color/native_background</item>
        <item name="android:windowBackground">@color/native_background</item>
        <item name="android:forceDarkAllowed">false</item>
    </style>

    <style name="ScannerTheme" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:windowActionBar">false</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:statusBarColor">@color/scanner_chrome</item>
        <item name="android:navigationBarColor">@color/scanner_chrome</item>
        <item name="android:forceDarkAllowed">false</item>
    </style>
</resources>

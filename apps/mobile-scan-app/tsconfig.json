{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "types": ["node"],
    "rootDir": "."
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "__tests__/**/*.ts"],
  "exclude": [".test-output", "node_modules"]
}

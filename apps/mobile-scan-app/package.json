{
  "name": "mobile-scan-app",
  "version": "0.1.0",
  "private": true,
  "main": "index.js",
  "scripts": {
    "android": "react-native run-android",
    "android:check": "node scripts/native-auth-platform-check.mjs android",
    "build": "tsc --noEmit --pretty false",
    "ios": "react-native run-ios",
    "ios:check": "node scripts/native-auth-platform-check.mjs ios",
    "lint": "tsc --noEmit --pretty false",
    "package:check": "node scripts/packaging-readiness.mjs",
    "start": "react-native start",
    "test": "tsc -p tsconfig.test.json && node --test .test-output/__tests__/*.test.js",
    "typecheck": "tsc --noEmit --pretty false",
    "windows": "react-native run-windows",
    "windows:check": "node scripts/windows-msix-readiness.mjs"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "react": "19.2.3",
    "react-native": "0.84.1",
    "react-native-windows": "0.84.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "20.1.0",
    "@react-native-community/cli-platform-android": "20.1.0",
    "@react-native-community/cli-platform-ios": "20.1.0",
    "@react-native/babel-preset": "0.84.1",
    "@react-native/codegen": "0.84.1",
    "@react-native/metro-config": "0.84.1",
    "@react-native/typescript-config": "0.84.1",
    "@react-native/gradle-plugin": "0.84.1",
    "@types/node": "^20",
    "@types/react": "^19.2.0",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=22.11.0"
  }
}

# This `.xcode.env` file is versioned and is used to source the environment
# used when running script phases inside Xcode.
# To customize your local environment, you can create an `.xcode.env.local`
# file that is not versioned.

# NODE_BINARY variable contains the PATH to the node executable.
#
# React Native 0.84/Metro requires a modern Node runtime. Xcode script phases
# run in a non-login shell, so prefer the repo developer runtime when mise is
# available, then fall back to PATH for CI/build machines without mise.
if command -v mise >/dev/null 2>&1; then
  MISE_NODE_BINARY="$(mise which node 2>/dev/null || true)"
fi

if [ -n "${MISE_NODE_BINARY:-}" ]; then
  export NODE_BINARY="$MISE_NODE_BINARY"
else
  export NODE_BINARY="$(command -v node)"
fi

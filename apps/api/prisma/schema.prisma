generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  OFFICE
  WAREHOUSE
  SYSTEM
}

enum ImportStatus {
  UPLOADED
  DUPLICATE
  FAILED
}

enum ParseStatus {
  NOT_PARSED
  PARSING
  PARSED
  REVIEW_REQUIRED
  WARNING
  ERROR
}

enum ParserSourceKind {
  BUILT_IN
  MANUAL
  PROFILE
}

enum ParserProfileLifecycle {
  DRAFT
  ACTIVE
  PAUSED
  RETIRED
}

enum ParserProfileTrustState {
  REVIEW_REQUIRED
  TRUSTED
}

enum ParserLearningCaseStatus {
  OPEN
  MAPPING
  READY_FOR_REPLAY
  REPLAY_FAILED
  AWAITING_COMPLETION
  AWAITING_APPROVAL
  CLOSED
}

enum ParserProfileEvidenceOutcome {
  ACCEPTED
  MATERIAL_CORRECTION
}

enum ParserProfileAuditEventCode {
  PROFILE_CREATED
  CASE_CREATED
  CONTAINER_LINKED
  CONTAINER_UNLINKED
  MAPPING_SAVED
  SUBMITTED
  REPLAYED
  PROFILE_APPROVED
  EVIDENCE_ACCEPTED
  EVIDENCE_MATERIAL_CORRECTION
  PROFILE_TRUSTED
  PROFILE_PAUSED
  PROFILE_RESUMED
  PROFILE_RETIRED
  PROFILE_VERSION_FORKED
  CASE_CLOSED
  IMPORT_DELETE_BLOCKED
}

enum FileFormat {
  UNLOADING_PLAN_CN
  BESTAR_RECEIVING
  UNKNOWN
}

enum ContainerStatus {
  IMPORTED
  PARSED
  CORRECTED
  REPORT_GENERATED
  LABELS_GENERATED
  UNLOADED
  LOADING_IN_PROGRESS
  LOADED
  ERROR
}

enum GeneratedFileType {
  PARSED_JSON
  EXCEL_REPORT
  PALLET_LABEL_PDF
  TASK_REPORT_HTML
  CORRECTIONS_JSON
  MONTHLY_UNLOADING_SUMMARY_XLSX
  PARSER_PROFILE_REPLAY_JSON
}

enum GeneratedFileStatus {
  GENERATING
  GENERATED
  FAILED
  SUPERSEDED
}

enum AsyncJobType {
  UNLOADING_PARSE
  UNLOADING_REPORT
  UNLOADING_LABELS
  ATTENDANCE_PARSE
  WAGE_RECORD_GENERATION
  PARSER_PROFILE_REPLAY
}

enum AsyncJobStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
  CANCELLED
}

enum PalletStatus {
  PLANNED
  LABEL_PRINTED
  LOADING
  LOADED
  ADJUSTED_OUT
  CANCELLED
  EXCEPTION
}

enum LoadJobStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum PalletEventType {
  CREATED
  LABEL_PRINTED
  SCANNED
  LOADED
  DUPLICATE_SCAN
  INVALID_SCAN
  STATUS_CHANGED
  CANCELLED
  REPRINTED
  MANUAL_INVENTORY_DEPLETION
}

enum InventoryAdjustmentType {
  MANUAL_DEPLETION
}

enum InventoryAdjustmentReasonCode {
  DELIVERED_WITHOUT_SCAN
  SCAN_MISSED
  DATA_CLEANUP
  OTHER
}

enum CorrectionTargetType {
  IMPORT_FILE
  CONTAINER
  CONTAINER_LINE
  CONTAINER_DESTINATION
  PALLET
  GENERATED_FILE
  ATTENDANCE_IMPORT
  PAY_CONTAINER
  UNLOADING_WAGE_SETTLEMENT
}

enum WageGeneratedFileType {
  ATTENDANCE_PARSED_JSON
  WAGE_RECORD_XLS
  TASK_REPORT_HTML
  UNLOADING_WAGE_SETTLEMENT_JSON
  UNLOADING_WAGE_TASK_REPORT_HTML
}

enum ContainerPayClassification {
  OCEAN_CONTAINER
  US_TO_CANADA_TRANSFER
}

enum PayAllocationMethod {
  EQUAL_SPLIT
  MANUAL_AMOUNT
  MANUAL_PERCENT
}

enum PayContainerStatus {
  DRAFT
  COMPLETED
  SETTLED
  NEEDS_REVIEW
}

enum UnloadingWageSettlementStatus {
  GENERATED
  SUPERSEDED
  NEEDS_REVIEW
}

model User {
  id                            String                    @id @default(cuid())
  email                         String?                   @unique
  name                          String?
  passwordHash                  String?                   @map("password_hash")
  lastLoginAt                   DateTime?                 @map("last_login_at")
  /// Legacy single-role value retained until auth APIs fully read user_roles.
  role                          UserRole                  @default(OFFICE)
  isActive                      Boolean                   @default(true) @map("is_active")
  roleAssignments               UserRoleAssignment[]
  assignedUserRoles             UserRoleAssignment[]      @relation("UserRoleAssignedBy")
  importedFiles                 ImportFile[]              @relation("ImportFileImportedBy")
  deletedImportFiles            ImportFile[]              @relation("ImportFileDeletedBy")
  generatedFiles                GeneratedFile[]           @relation("GeneratedFileGeneratedBy")
  loadJobs                      LoadJob[]                 @relation("LoadJobCreatedBy")
  palletEvents                  PalletEvent[]             @relation("PalletEventOperator")
  inventoryAdjustments          InventoryAdjustment[]     @relation("InventoryAdjustmentCreatedBy")
  correctionFeedback            CorrectionFeedback[]      @relation("CorrectionFeedbackCorrectedBy")
  operationalSettings           OperationalSetting[]      @relation("OperationalSettingUpdatedBy")
  attendanceImports             AttendanceImport[]        @relation("AttendanceImportImportedBy")
  wageGeneratedFiles            WageGeneratedFile[]       @relation("WageGeneratedFileGeneratedBy")
  asyncJobs                     AsyncJob[]                @relation("AsyncJobActor")
  payContainersCreated          PayContainer[]            @relation("PayContainerCreatedBy")
  payContainersCompleted        PayContainer[]            @relation("PayContainerCompletedBy")
  unloaderAssignments           UnloaderAssignment[]      @relation("UnloaderAssignmentUser")
  unloadingWorkersCreated       UnloadingWorker[]         @relation("UnloadingWorkerCreatedBy")
  unloadingWorkersUpdated       UnloadingWorker[]         @relation("UnloadingWorkerUpdatedBy")
  wageSettlementsGenerated      UnloadingWageSettlement[] @relation("UnloadingWageSettlementGeneratedBy")
  nativeAuthSessions            NativeAuthSession[]
  revokedNativeAuthSessions     NativeAuthSession[]       @relation("NativeAuthSessionRevokedBy")
  parserProfileFamiliesCreated  ParserProfileFamily[]     @relation("ParserProfileFamilyCreatedBy")
  parserProfileVersionsCreated  ParserProfileVersion[]    @relation("ParserProfileVersionCreatedBy")
  parserProfileVersionsApproved ParserProfileVersion[]    @relation("ParserProfileVersionApprovedBy")
  parserLearningCasesCreated    ParserLearningCase[]      @relation("ParserLearningCaseCreatedBy")
  parserLearningCasesUpdated    ParserLearningCase[]      @relation("ParserLearningCaseUpdatedBy")
  parserLearningCasesClosed     ParserLearningCase[]      @relation("ParserLearningCaseClosedBy")
  parserProfileEvidenceReviewed ParserProfileEvidence[]   @relation("ParserProfileEvidenceReviewedBy")
  parserProfileAuditEvents      ParserProfileAuditEvent[] @relation("ParserProfileAuditActor")
  createdAt                     DateTime                  @default(now()) @map("created_at")
  updatedAt                     DateTime                  @updatedAt @map("updated_at")

  @@map("users")
}

model NativeAuthSession {
  id                       String               @id @default(cuid())
  userId                   String               @map("user_id")
  user                     User                 @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  deviceId                 String               @map("device_id")
  platform                 String?
  appVersion               String?              @map("app_version")
  refreshTokenHash         String               @unique @map("refresh_token_hash")
  previousRefreshTokenHash String?              @map("previous_refresh_token_hash")
  createdAt                DateTime             @default(now()) @map("created_at")
  lastUsedAt               DateTime             @default(now()) @map("last_used_at")
  rotatedAt                DateTime?            @map("rotated_at")
  revokedAt                DateTime?            @map("revoked_at")
  revokedByUserId          String?              @map("revoked_by_user_id")
  revokedByUser            User?                @relation("NativeAuthSessionRevokedBy", fields: [revokedByUserId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  revokeReason             String?              @map("revoke_reason")
  expiresAt                DateTime             @map("expires_at")
  absoluteExpiresAt        DateTime             @map("absolute_expires_at")
  refreshTokens            NativeRefreshToken[]

  @@index([userId, revokedAt])
  @@index([expiresAt])
  @@map("native_auth_sessions")
}

model NativeRefreshToken {
  id                  String            @id @default(cuid())
  sessionId           String            @map("session_id")
  session             NativeAuthSession @relation(fields: [sessionId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  tokenHash           String            @unique @map("token_hash")
  issuedAt            DateTime          @default(now()) @map("issued_at")
  usedAt              DateTime?         @map("used_at")
  revokedAt           DateTime?         @map("revoked_at")
  expiresAt           DateTime          @map("expires_at")
  replacedByTokenHash String?           @map("replaced_by_token_hash")

  @@index([sessionId, issuedAt])
  @@index([expiresAt])
  @@map("native_refresh_tokens")
}

model Role {
  id              String               @id @default(cuid())
  code            String               @unique
  displayName     String               @map("display_name")
  description     String?
  isSystem        Boolean              @default(false) @map("is_system")
  isActive        Boolean              @default(true) @map("is_active")
  userAssignments UserRoleAssignment[]
  permissions     RolePermission[]
  createdAt       DateTime             @default(now()) @map("created_at")
  updatedAt       DateTime             @updatedAt @map("updated_at")

  @@index([isActive])
  @@index([isSystem])
  @@map("roles")
}

model Permission {
  id          String           @id @default(cuid())
  code        String           @unique
  category    String?
  description String?
  isSystem    Boolean          @default(true) @map("is_system")
  roles       RolePermission[]
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  @@index([category])
  @@index([isSystem])
  @@map("permissions")
}

model UserRoleAssignment {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  roleId       String   @map("role_id")
  role         Role     @relation(fields: [roleId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  assignedById String?  @map("assigned_by_id")
  assignedBy   User?    @relation("UserRoleAssignedBy", fields: [assignedById], references: [id], onDelete: SetNull, onUpdate: Cascade)
  assignedAt   DateTime @default(now()) @map("assigned_at")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
  @@index([assignedById])
  @@map("user_roles")
}

model RolePermission {
  id           String     @id @default(cuid())
  roleId       String     @map("role_id")
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  permissionId String     @map("permission_id")
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
  @@map("role_permissions")
}

model ImportFile {
  id                       String                    @id @default(cuid())
  originalFilename         String                    @map("original_filename")
  storedPath               String                    @map("stored_path")
  fileSha256               String                    @unique @map("file_sha256")
  mimeType                 String?                   @map("mime_type")
  fileSizeBytes            BigInt?                   @map("file_size_bytes")
  format                   FileFormat                @default(UNKNOWN)
  importStatus             ImportStatus              @default(UPLOADED) @map("import_status")
  parseStatus              ParseStatus               @default(NOT_PARSED) @map("parse_status")
  parserVersion            String?                   @map("parser_version")
  warningCount             Int                       @default(0) @map("warning_count")
  errorCount               Int                       @default(0) @map("error_count")
  errorMessage             String?                   @map("error_message")
  rawMetadata              Json?                     @map("raw_metadata")
  importedById             String?                   @map("imported_by_id")
  importedBy               User?                     @relation("ImportFileImportedBy", fields: [importedById], references: [id], onDelete: SetNull, onUpdate: Cascade)
  deletedAt                DateTime?                 @map("deleted_at")
  deletedById              String?                   @map("deleted_by_id")
  deletedBy                User?                     @relation("ImportFileDeletedBy", fields: [deletedById], references: [id], onDelete: SetNull, onUpdate: Cascade)
  deleteReason             String?                   @map("delete_reason")
  containers               Container[]
  generatedFiles           GeneratedFile[]
  asyncJobs                AsyncJob[]
  correctionFeedback       CorrectionFeedback[]
  parserLearningCases      ParserLearningCase[]      @relation("LearningCaseSourceImport")
  parserProfileEvidence    ParserProfileEvidence[]
  parserProfileAuditEvents ParserProfileAuditEvent[]
  createdAt                DateTime                  @default(now()) @map("created_at")
  updatedAt                DateTime                  @updatedAt @map("updated_at")

  @@index([format])
  @@index([importStatus])
  @@index([parseStatus])
  @@index([deletedAt])
  @@index([deletedById])
  @@index([createdAt])
  @@map("import_files")
}

model Container {
  id                       String                      @id @default(cuid())
  importFileId             String?                     @map("import_file_id")
  importFile               ImportFile?                 @relation(fields: [importFileId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  containerNo              String                      @unique @map("container_no")
  sourceFormat             FileFormat                  @default(UNKNOWN) @map("source_format")
  parserVersion            String?                     @map("parser_version")
  parserSourceKind         ParserSourceKind            @default(BUILT_IN) @map("parser_source_kind")
  parserProfileVersionId   String?                     @map("parser_profile_version_id")
  parserProfileVersion     ParserProfileVersion?       @relation(fields: [parserProfileVersionId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  dockNo                   String?                     @map("dock_no")
  company                  String?
  status                   ContainerStatus             @default(IMPORTED)
  rawJson                  Json?                       @map("raw_json")
  warnings                 Json?
  errors                   Json?
  payClassification        ContainerPayClassification? @map("pay_classification")
  payTrailerNumber         String?                     @map("pay_trailer_number")
  payContainerLinks        PayContainerContainer[]
  lines                    ContainerLine[]
  destinations             ContainerDestination[]
  generatedFiles           GeneratedFile[]
  asyncJobs                AsyncJob[]
  loadJobs                 LoadJob[]
  loadJobLines             LoadJobLine[]
  inventoryAdjustments     InventoryAdjustment[]
  correctionFeedback       CorrectionFeedback[]
  parserLearningCase       ParserLearningCase?
  parserProfileAuditEvents ParserProfileAuditEvent[]
  createdAt                DateTime                    @default(now()) @map("created_at")
  updatedAt                DateTime                    @updatedAt @map("updated_at")

  @@index([importFileId])
  @@index([parserSourceKind])
  @@index([parserProfileVersionId])
  @@index([status])
  @@index([payClassification])
  @@index([payTrailerNumber])
  @@index([createdAt])
  @@map("containers")
}

model ParserProfileFamily {
  id            String                    @id @default(cuid())
  stableName    String                    @unique @map("stable_name")
  customerLabel String?                   @map("customer_label")
  createdById   String                    @map("created_by_id")
  createdBy     User                      @relation("ParserProfileFamilyCreatedBy", fields: [createdById], references: [id], onDelete: Restrict, onUpdate: Cascade)
  versions      ParserProfileVersion[]
  auditEvents   ParserProfileAuditEvent[]
  createdAt     DateTime                  @default(now()) @map("created_at")
  updatedAt     DateTime                  @updatedAt @map("updated_at")

  @@index([createdById])
  @@index([createdAt])
  @@map("parser_profile_families")
}

model ParserProfileVersion {
  id                    String                    @id @default(cuid())
  familyId              String                    @map("family_id")
  family                ParserProfileFamily       @relation(fields: [familyId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  sourceLearningCaseId  String?                   @map("source_learning_case_id")
  sourceLearningCase    ParserLearningCase?       @relation(fields: [sourceLearningCaseId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  sourceDraftRevision   Int?                      @map("source_draft_revision")
  version               Int
  lifecycle             ParserProfileLifecycle    @default(DRAFT)
  trustState            ParserProfileTrustState   @default(REVIEW_REQUIRED) @map("trust_state")
  mappingDefinition     Json                      @map("mapping_definition")
  fingerprintDefinition Json                      @map("fingerprint_definition")
  matcherVersion        String                    @map("matcher_version")
  mappingVersion        String                    @map("mapping_version")
  createdById           String                    @map("created_by_id")
  createdBy             User                      @relation("ParserProfileVersionCreatedBy", fields: [createdById], references: [id], onDelete: Restrict, onUpdate: Cascade)
  approvedById          String?                   @map("approved_by_id")
  approvedBy            User?                     @relation("ParserProfileVersionApprovedBy", fields: [approvedById], references: [id], onDelete: Restrict, onUpdate: Cascade)
  approvedAt            DateTime?                 @map("approved_at")
  approvalReason        String?                   @map("approval_reason")
  lifecycleReason       String?                   @map("lifecycle_reason")
  lifecycleRevision     Int                       @default(0) @map("lifecycle_revision")
  trustStreak           Int                       @default(0) @map("trust_streak")
  containers            Container[]
  evidence              ParserProfileEvidence[]
  auditEvents           ParserProfileAuditEvent[]
  createdAt             DateTime                  @default(now()) @map("created_at")
  updatedAt             DateTime                  @updatedAt @map("updated_at")

  @@unique([familyId, version])
  @@unique([sourceLearningCaseId, sourceDraftRevision])
  @@index([lifecycle, trustState])
  @@index([sourceLearningCaseId])
  @@index([createdById])
  @@index([approvedById])
  @@index([createdAt])
  @@map("parser_profile_versions")
}

model ParserLearningCase {
  id                      String                    @id @default(cuid())
  sourceImportId          String?                   @unique @map("source_import_id")
  sourceImport            ImportFile?               @relation("LearningCaseSourceImport", fields: [sourceImportId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  sourceImportReferenceId String                    @map("source_import_reference_id")
  sourceFileSha256        String                    @map("source_file_sha256")
  linkedContainerId       String?                   @unique @map("linked_container_id")
  linkedContainer         Container?                @relation(fields: [linkedContainerId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  status                  ParserLearningCaseStatus  @default(OPEN)
  draftDefinition         Json?                     @map("draft_definition")
  draftRevision           Int                       @default(0) @map("draft_revision")
  completionSnapshot      Json?                     @map("completion_snapshot")
  completionSnapshotAt    DateTime?                 @map("completion_snapshot_at")
  completionReplayJobId   String?                   @unique @map("completion_replay_job_id")
  completionReplayJob     AsyncJob?                 @relation("ParserCompletionReplayJob", fields: [completionReplayJobId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  replaySummary           Json?                     @map("replay_summary")
  activeReplayToken       String?                   @map("active_replay_token")
  lastErrorCode           String?                   @map("last_error_code")
  createdById             String                    @map("created_by_id")
  createdBy               User                      @relation("ParserLearningCaseCreatedBy", fields: [createdById], references: [id], onDelete: Restrict, onUpdate: Cascade)
  updatedById             String                    @map("updated_by_id")
  updatedBy               User                      @relation("ParserLearningCaseUpdatedBy", fields: [updatedById], references: [id], onDelete: Restrict, onUpdate: Cascade)
  closedById              String?                   @map("closed_by_id")
  closedBy                User?                     @relation("ParserLearningCaseClosedBy", fields: [closedById], references: [id], onDelete: Restrict, onUpdate: Cascade)
  closedAt                DateTime?                 @map("closed_at")
  auditEvents             ParserProfileAuditEvent[]
  profileVersions         ParserProfileVersion[]
  generatedFiles          GeneratedFile[]           @relation("ParserLearningCaseGeneratedFiles")
  asyncJobs               AsyncJob[]                @relation("ParserLearningCaseAsyncJobs")
  createdAt               DateTime                  @default(now()) @map("created_at")
  updatedAt               DateTime                  @updatedAt @map("updated_at")

  @@index([sourceImportReferenceId])
  @@index([sourceFileSha256])
  @@index([status])
  @@index([createdById])
  @@index([updatedById])
  @@index([closedById])
  @@index([createdAt])
  @@map("parser_learning_cases")
}

model ParserProfileEvidence {
  id                 String                       @id @default(cuid())
  profileVersionId   String                       @map("profile_version_id")
  profileVersion     ParserProfileVersion         @relation(fields: [profileVersionId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  importFileId       String                       @map("import_file_id")
  importFile         ImportFile                   @relation(fields: [importFileId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  outcome            ParserProfileEvidenceOutcome
  accepted           Boolean                      @default(false)
  materialCorrection Boolean                      @default(false) @map("material_correction")
  resultSnapshot     Json?                        @map("result_snapshot")
  correctionDiff     Json?                        @map("correction_diff")
  reviewedById       String                       @map("reviewed_by_id")
  reviewedBy         User                         @relation("ParserProfileEvidenceReviewedBy", fields: [reviewedById], references: [id], onDelete: Restrict, onUpdate: Cascade)
  reviewedAt         DateTime                     @default(now()) @map("reviewed_at")
  createdAt          DateTime                     @default(now()) @map("created_at")
  updatedAt          DateTime                     @updatedAt @map("updated_at")

  @@unique([profileVersionId, importFileId])
  @@index([importFileId])
  @@index([outcome])
  @@index([reviewedById])
  @@index([reviewedAt])
  @@map("parser_profile_evidence")
}

model ParserProfileAuditEvent {
  id               String                      @id @default(cuid())
  eventCode        ParserProfileAuditEventCode @map("event_code")
  actorId          String                      @map("actor_id")
  actor            User                        @relation("ParserProfileAuditActor", fields: [actorId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  profileFamilyId  String?                     @map("profile_family_id")
  profileFamily    ParserProfileFamily?        @relation(fields: [profileFamilyId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  profileVersionId String?                     @map("profile_version_id")
  profileVersion   ParserProfileVersion?       @relation(fields: [profileVersionId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  learningCaseId   String?                     @map("learning_case_id")
  learningCase     ParserLearningCase?         @relation(fields: [learningCaseId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  importFileId     String?                     @map("import_file_id")
  importFile       ImportFile?                 @relation(fields: [importFileId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  containerId      String?                     @map("container_id")
  container        Container?                  @relation(fields: [containerId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  metadata         Json?
  occurredAt       DateTime                    @default(now()) @map("occurred_at")
  createdAt        DateTime                    @default(now()) @map("created_at")

  @@index([eventCode])
  @@index([actorId])
  @@index([profileFamilyId])
  @@index([profileVersionId])
  @@index([learningCaseId])
  @@index([importFileId])
  @@index([containerId])
  @@index([occurredAt])
  @@map("parser_profile_audit_events")
}

model ContainerLine {
  id                 String               @id @default(cuid())
  containerId        String               @map("container_id")
  container          Container            @relation(fields: [containerId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  lineNo             Int                  @map("line_no")
  destinationCode    String?              @map("destination_code")
  destinationType    String?              @map("destination_type")
  cartons            Int?
  volume             Decimal?             @db.Decimal(12, 3)
  rawJson            Json                 @map("raw_json")
  warnings           Json?
  errors             Json?
  correctionFeedback CorrectionFeedback[]
  createdAt          DateTime             @default(now()) @map("created_at")
  updatedAt          DateTime             @updatedAt @map("updated_at")

  @@unique([containerId, lineNo])
  @@index([containerId])
  @@index([destinationCode])
  @@map("container_lines")
}

model DestinationRule {
  id              String                 @id @default(cuid())
  destinationCode String                 @unique @map("destination_code")
  destinationType String?                @map("destination_type")
  displayName     String?                @map("display_name")
  palletRule      Json?                  @map("pallet_rule")
  isActive        Boolean                @default(true) @map("is_active")
  destinations    ContainerDestination[]
  createdAt       DateTime               @default(now()) @map("created_at")
  updatedAt       DateTime               @updatedAt @map("updated_at")

  @@index([isActive])
  @@map("destination_rules")
}

model ContainerDestination {
  id                   String                @id @default(cuid())
  containerId          String                @map("container_id")
  container            Container             @relation(fields: [containerId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  destinationCode      String                @map("destination_code")
  destinationType      String?               @map("destination_type")
  packageType          String                @default("UNSPECIFIED") @map("package_type")
  cartons              Int                   @default(0)
  volume               Decimal               @default(0) @db.Decimal(12, 3)
  calculatedPallets    Int                   @default(0) @map("calculated_pallets")
  manualPallets        Int?                  @map("manual_pallets")
  finalPallets         Int                   @default(0) @map("final_pallets")
  palletRuleCode       String?               @map("pallet_rule_code")
  calculationBasisCbm  Decimal?              @map("calculation_basis_cbm") @db.Decimal(12, 3)
  roundingMode         String?               @map("rounding_mode")
  palletPolicySnapshot Json?                 @map("pallet_policy_snapshot")
  note                 String?
  warnings             Json?
  errors               Json?
  destinationRuleId    String?               @map("destination_rule_id")

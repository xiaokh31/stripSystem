generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  OFFICE
  WAREHOUSE
  SYSTEM
}

enum ImportStatus {
  UPLOADED
  DUPLICATE
  FAILED
}

enum ParseStatus {
  NOT_PARSED
  PARSING
  PARSED
  WARNING
  ERROR
}

enum FileFormat {
  UNLOADING_PLAN_CN
  BESTAR_RECEIVING
  UNKNOWN
}

enum ContainerStatus {
  IMPORTED
  PARSED
  CORRECTED
  REPORT_GENERATED
  LABELS_GENERATED
  LOADING_IN_PROGRESS
  LOADED
  ERROR
}

enum GeneratedFileType {
  PARSED_JSON
  EXCEL_REPORT
  PALLET_LABEL_PDF
  TASK_REPORT_HTML
  CORRECTIONS_JSON
}

enum GeneratedFileStatus {
  GENERATED
  FAILED
  SUPERSEDED
}

enum PalletStatus {
  PLANNED
  LABEL_PRINTED
  LOADING
  LOADED
  CANCELLED
  EXCEPTION
}

enum LoadJobStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum PalletEventType {
  CREATED
  LABEL_PRINTED
  SCANNED
  LOADED
  DUPLICATE_SCAN
  INVALID_SCAN
  STATUS_CHANGED
  CANCELLED
  REPRINTED
}

enum CorrectionTargetType {
  IMPORT_FILE
  CONTAINER
  CONTAINER_LINE
  CONTAINER_DESTINATION
  PALLET
  GENERATED_FILE
  ATTENDANCE_IMPORT
  PAY_CONTAINER
  UNLOADING_WAGE_SETTLEMENT
}

enum WageGeneratedFileType {
  ATTENDANCE_PARSED_JSON
  WAGE_RECORD_XLS
  TASK_REPORT_HTML
  UNLOADING_WAGE_SETTLEMENT_JSON
  UNLOADING_WAGE_TASK_REPORT_HTML
}

enum ContainerPayClassification {
  OCEAN_CONTAINER
  US_TO_CANADA_TRANSFER
}

enum PayAllocationMethod {
  EQUAL_SPLIT
  MANUAL_AMOUNT
  MANUAL_PERCENT
}

enum PayContainerStatus {
  DRAFT
  COMPLETED
  SETTLED
  NEEDS_REVIEW
}

enum UnloadingWageSettlementStatus {
  GENERATED
  SUPERSEDED
  NEEDS_REVIEW
}

model User {
  id                       String                    @id @default(cuid())
  email                    String?                   @unique
  name                     String?
  passwordHash             String?                   @map("password_hash")
  lastLoginAt              DateTime?                 @map("last_login_at")
  /// Legacy single-role value retained until auth APIs fully read user_roles.
  role                     UserRole                  @default(OFFICE)
  isActive                 Boolean                   @default(true) @map("is_active")
  roleAssignments          UserRoleAssignment[]
  assignedUserRoles        UserRoleAssignment[]      @relation("UserRoleAssignedBy")
  importedFiles            ImportFile[]              @relation("ImportFileImportedBy")
  deletedImportFiles       ImportFile[]              @relation("ImportFileDeletedBy")
  generatedFiles           GeneratedFile[]           @relation("GeneratedFileGeneratedBy")
  loadJobs                 LoadJob[]                 @relation("LoadJobCreatedBy")
  palletEvents             PalletEvent[]             @relation("PalletEventOperator")
  correctionFeedback       CorrectionFeedback[]      @relation("CorrectionFeedbackCorrectedBy")
  operationalSettings      OperationalSetting[]      @relation("OperationalSettingUpdatedBy")
  attendanceImports        AttendanceImport[]        @relation("AttendanceImportImportedBy")
  wageGeneratedFiles       WageGeneratedFile[]       @relation("WageGeneratedFileGeneratedBy")
  payContainersCreated     PayContainer[]            @relation("PayContainerCreatedBy")
  payContainersCompleted   PayContainer[]            @relation("PayContainerCompletedBy")
  unloaderAssignments      UnloaderAssignment[]      @relation("UnloaderAssignmentUser")
  unloadingWorkersCreated  UnloadingWorker[]         @relation("UnloadingWorkerCreatedBy")
  unloadingWorkersUpdated  UnloadingWorker[]         @relation("UnloadingWorkerUpdatedBy")
  wageSettlementsGenerated UnloadingWageSettlement[] @relation("UnloadingWageSettlementGeneratedBy")
  createdAt                DateTime                  @default(now()) @map("created_at")
  updatedAt                DateTime                  @updatedAt @map("updated_at")

  @@map("users")
}

model Role {
  id              String               @id @default(cuid())
  code            String               @unique
  displayName     String               @map("display_name")
  description     String?
  isSystem        Boolean              @default(false) @map("is_system")
  isActive        Boolean              @default(true) @map("is_active")
  userAssignments UserRoleAssignment[]
  permissions     RolePermission[]
  createdAt       DateTime             @default(now()) @map("created_at")
  updatedAt       DateTime             @updatedAt @map("updated_at")

  @@index([isActive])
  @@index([isSystem])
  @@map("roles")
}

model Permission {
  id          String           @id @default(cuid())
  code        String           @unique
  category    String?
  description String?
  isSystem    Boolean          @default(true) @map("is_system")
  roles       RolePermission[]
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  @@index([category])
  @@index([isSystem])
  @@map("permissions")
}

model UserRoleAssignment {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  roleId       String   @map("role_id")
  role         Role     @relation(fields: [roleId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  assignedById String?  @map("assigned_by_id")
  assignedBy   User?    @relation("UserRoleAssignedBy", fields: [assignedById], references: [id], onDelete: SetNull, onUpdate: Cascade)
  assignedAt   DateTime @default(now()) @map("assigned_at")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
  @@index([assignedById])
  @@map("user_roles")
}

model RolePermission {
  id           String     @id @default(cuid())
  roleId       String     @map("role_id")
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  permissionId String     @map("permission_id")
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
  @@map("role_permissions")
}

model ImportFile {
  id                 String               @id @default(cuid())
  originalFilename   String               @map("original_filename")
  storedPath         String               @map("stored_path")
  fileSha256         String               @unique @map("file_sha256")
  mimeType           String?              @map("mime_type")
  fileSizeBytes      BigInt?              @map("file_size_bytes")
  format             FileFormat           @default(UNKNOWN)
  importStatus       ImportStatus         @default(UPLOADED) @map("import_status")
  parseStatus        ParseStatus          @default(NOT_PARSED) @map("parse_status")
  parserVersion      String?              @map("parser_version")
  warningCount       Int                  @default(0) @map("warning_count")
  errorCount         Int                  @default(0) @map("error_count")
  errorMessage       String?              @map("error_message")
  rawMetadata        Json?                @map("raw_metadata")
  importedById       String?              @map("imported_by_id")
  importedBy         User?                @relation("ImportFileImportedBy", fields: [importedById], references: [id], onDelete: SetNull, onUpdate: Cascade)
  deletedAt          DateTime?            @map("deleted_at")
  deletedById        String?              @map("deleted_by_id")
  deletedBy          User?                @relation("ImportFileDeletedBy", fields: [deletedById], references: [id], onDelete: SetNull, onUpdate: Cascade)
  deleteReason       String?              @map("delete_reason")
  containers         Container[]
  generatedFiles     GeneratedFile[]
  correctionFeedback CorrectionFeedback[]
  createdAt          DateTime             @default(now()) @map("created_at")
  updatedAt          DateTime             @updatedAt @map("updated_at")

  @@index([format])
  @@index([importStatus])
  @@index([parseStatus])
  @@index([deletedAt])
  @@index([deletedById])
  @@index([createdAt])
  @@map("import_files")
}

model Container {
  id                 String                      @id @default(cuid())
  importFileId       String?                     @map("import_file_id")
  importFile         ImportFile?                 @relation(fields: [importFileId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  containerNo        String                      @unique @map("container_no")
  sourceFormat       FileFormat                  @default(UNKNOWN) @map("source_format")
  parserVersion      String?                     @map("parser_version")
  dockNo             String?                     @map("dock_no")
  company            String?
  status             ContainerStatus             @default(IMPORTED)
  rawJson            Json?                       @map("raw_json")
  warnings           Json?
  errors             Json?
  payClassification  ContainerPayClassification? @map("pay_classification")
  payTrailerNumber   String?                     @map("pay_trailer_number")
  payContainerLinks  PayContainerContainer[]
  lines              ContainerLine[]
  destinations       ContainerDestination[]
  generatedFiles     GeneratedFile[]
  loadJobs           LoadJob[]
  loadJobLines       LoadJobLine[]
  correctionFeedback CorrectionFeedback[]
  createdAt          DateTime                    @default(now()) @map("created_at")
  updatedAt          DateTime                    @updatedAt @map("updated_at")

  @@index([importFileId])
  @@index([status])
  @@index([payClassification])
  @@index([payTrailerNumber])
  @@index([createdAt])
  @@map("containers")
}

model ContainerLine {
  id                 String               @id @default(cuid())
  containerId        String               @map("container_id")
  container          Container            @relation(fields: [containerId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  lineNo             Int                  @map("line_no")
  destinationCode    String?              @map("destination_code")
  destinationType    String?              @map("destination_type")
  cartons            Int?
  volume             Decimal?             @db.Decimal(12, 3)
  rawJson            Json                 @map("raw_json")
  warnings           Json?
  errors             Json?
  correctionFeedback CorrectionFeedback[]
  createdAt          DateTime             @default(now()) @map("created_at")
  updatedAt          DateTime             @updatedAt @map("updated_at")

  @@unique([containerId, lineNo])
  @@index([containerId])
  @@index([destinationCode])
  @@map("container_lines")
}

model DestinationRule {
  id              String                 @id @default(cuid())
  destinationCode String                 @unique @map("destination_code")
  destinationType String?                @map("destination_type")
  displayName     String?                @map("display_name")
  palletRule      Json?                  @map("pallet_rule")
  isActive        Boolean                @default(true) @map("is_active")
  destinations    ContainerDestination[]
  createdAt       DateTime               @default(now()) @map("created_at")
  updatedAt       DateTime               @updatedAt @map("updated_at")

  @@index([isActive])
  @@map("destination_rules")
}

model ContainerDestination {
  id                 String               @id @default(cuid())
  containerId        String               @map("container_id")
  container          Container            @relation(fields: [containerId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  destinationCode    String               @map("destination_code")
  destinationType    String?              @map("destination_type")
  cartons            Int                  @default(0)
  volume             Decimal              @default(0) @db.Decimal(12, 3)
  calculatedPallets  Int                  @default(0) @map("calculated_pallets")
  manualPallets      Int?                 @map("manual_pallets")
  finalPallets       Int                  @default(0) @map("final_pallets")
  note               String?
  warnings           Json?
  errors             Json?
  destinationRuleId  String?              @map("destination_rule_id")
  destinationRule    DestinationRule?     @relation(fields: [destinationRuleId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  pallets            Pallet[]
  loadJobLines       LoadJobLine[]
  correctionFeedback CorrectionFeedback[]
  createdAt          DateTime             @default(now()) @map("created_at")
  updatedAt          DateTime             @updatedAt @map("updated_at")

  @@unique([containerId, destinationCode, destinationType])
  @@index([containerId])
  @@index([destinationCode])
  @@index([destinationRuleId])
  @@map("container_destinations")
}

model Pallet {
  id                     String               @id @default(cuid())
  containerDestinationId String               @map("container_destination_id")
  containerDestination   ContainerDestination @relation(fields: [containerDestinationId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  palletNo               Int                  @map("pallet_no")
  palletId               String               @unique @map("pallet_id")
  qrPayload              String               @unique @map("qr_payload")
  status                 PalletStatus         @default(PLANNED)
  labelPrintedAt         DateTime?            @map("label_printed_at")
  loadedAt               DateTime?            @map("loaded_at")
  loadJobId              String?              @map("load_job_id")
  loadJob                LoadJob?             @relation(fields: [loadJobId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  events                 PalletEvent[]
  correctionFeedback     CorrectionFeedback[]
  createdAt              DateTime             @default(now()) @map("created_at")
  updatedAt              DateTime             @updatedAt @map("updated_at")

  @@unique([containerDestinationId, palletNo])
  @@index([containerDestinationId])
  @@index([status])
  @@index([loadJobId])
  @@map("pallets")
}

model GeneratedFile {
  id                 String               @id @default(cuid())
  importFileId       String?              @map("import_file_id")
  importFile         ImportFile?          @relation(fields: [importFileId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  containerId        String?              @map("container_id")
  container          Container?           @relation(fields: [containerId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  fileType           GeneratedFileType    @map("file_type")
  storagePath        String               @map("storage_path")
  fileSha256         String?              @map("file_sha256")
  mimeType           String?              @map("mime_type")
  fileSizeBytes      BigInt?              @map("file_size_bytes")
  status             GeneratedFileStatus  @default(GENERATED)
  errorMessage       String?              @map("error_message")
  generatedById      String?              @map("generated_by_id")
  generatedBy        User?                @relation("GeneratedFileGeneratedBy", fields: [generatedById], references: [id], onDelete: SetNull, onUpdate: Cascade)
  correctionFeedback CorrectionFeedback[]
  createdAt          DateTime             @default(now()) @map("created_at")
  updatedAt          DateTime             @updatedAt @map("updated_at")

  @@index([importFileId])
  @@index([containerId])
  @@index([fileType])
  @@index([status])
  @@index([createdAt])
  @@map("generated_files")
}

model LoadJob {
  id                   String        @id @default(cuid())
  containerId          String?       @map("container_id")
  container            Container?    @relation(fields: [containerId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  jobNo                String?       @unique @map("job_no")
  truckNo              String?       @map("truck_no")
  dockNo               String?       @map("dock_no")
  carrier              String?
  destinationRegion    String?       @map("destination_region")
  status               LoadJobStatus @default(PLANNED)
  startedAt            DateTime?     @map("started_at")
  scheduledDepartureAt DateTime?     @map("scheduled_departure_at")
  closedAt             DateTime?     @map("completed_at")
  createdById          String?       @map("created_by_id")
  createdBy            User?         @relation("LoadJobCreatedBy", fields: [createdById], references: [id], onDelete: SetNull, onUpdate: Cascade)
  lines                LoadJobLine[]
  pallets              Pallet[]
  events               PalletEvent[]
  createdAt            DateTime      @default(now()) @map("created_at")
  updatedAt            DateTime      @updatedAt @map("updated_at")

  @@index([containerId])
  @@index([status])
  @@index([createdAt])
  @@map("load_jobs")
}

model LoadJobLine {
  id                     String                @id @default(cuid())
  loadJobId              String                @map("load_job_id")
  loadJob                LoadJob               @relation(fields: [loadJobId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  sequence               Int                   @default(0)
  sourceText             String?               @map("source_text")
  containerNo            String?               @map("container_no")
  containerId            String?               @map("container_id")
  container              Container?            @relation(fields: [containerId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  containerDestinationId String?               @map("container_destination_id")
  containerDestination   ContainerDestination? @relation(fields: [containerDestinationId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  destinationCode        String?               @map("destination_code")
  plannedPallets         Int                   @default(0) @map("planned_pallets")
  externalTransfer       Boolean               @default(false) @map("external_transfer")
  note                   String?
  createdAt              DateTime              @default(now()) @map("created_at")
  updatedAt              DateTime              @updatedAt @map("updated_at")

  @@unique([loadJobId, sequence])
  @@index([loadJobId])
  @@index([containerId])
  @@index([containerDestinationId])
  @@index([destinationCode])
  @@index([externalTransfer])
  @@map("load_job_lines")
}

model PalletEvent {
  id              String          @id @default(cuid())
  palletId        String?         @map("pallet_id")
  pallet          Pallet?         @relation(fields: [palletId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  loadJobId       String?         @map("load_job_id")
  loadJob         LoadJob?        @relation(fields: [loadJobId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  eventType       PalletEventType @map("event_type")
  fromStatus      PalletStatus?   @map("from_status")
  toStatus        PalletStatus?   @map("to_status")
  scanPayload     String?         @map("scan_payload")
  deviceId        String?         @map("device_id")
  exceptionReason String?         @map("exception_reason")
  metadata        Json?
  operatorId      String?         @map("operator_id")
  operator        User?           @relation("PalletEventOperator", fields: [operatorId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  occurredAt      DateTime        @default(now()) @map("occurred_at")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  @@index([palletId])
  @@index([loadJobId])
  @@index([eventType])
  @@index([occurredAt])
  @@index([operatorId])
  @@map("pallet_events")
}

model CorrectionFeedback {
  id                        String                   @id @default(cuid())
  targetType                CorrectionTargetType     @map("target_type")
  importFileId              String?                  @map("import_file_id")
  importFile                ImportFile?              @relation(fields: [importFileId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  containerId               String?                  @map("container_id")
  container                 Container?               @relation(fields: [containerId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  containerLineId           String?                  @map("container_line_id")
  containerLine             ContainerLine?           @relation(fields: [containerLineId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  containerDestinationId    String?                  @map("container_destination_id")
  containerDestination      ContainerDestination?    @relation(fields: [containerDestinationId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  palletId                  String?                  @map("pallet_id")
  pallet                    Pallet?                  @relation(fields: [palletId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  generatedFileId           String?                  @map("generated_file_id")
  generatedFile             GeneratedFile?           @relation(fields: [generatedFileId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  attendanceImportId        String?                  @map("attendance_import_id")
  attendanceImport          AttendanceImport?        @relation(fields: [attendanceImportId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  payContainerId            String?                  @map("pay_container_id")
  payContainer              PayContainer?            @relation(fields: [payContainerId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  unloadingWageSettlementId String?                  @map("unloading_wage_settlement_id")
  unloadingWageSettlement   UnloadingWageSettlement? @relation(fields: [unloadingWageSettlementId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  fieldName                 String                   @map("field_name")
  oldValue                  Json?                    @map("old_value")
  newValue                  Json?                    @map("new_value")
  reason                    String?
  note                      String?
  correctedById             String?                  @map("corrected_by_id")
  correctedBy               User?                    @relation("CorrectionFeedbackCorrectedBy", fields: [correctedById], references: [id], onDelete: SetNull, onUpdate: Cascade)
  createdAt                 DateTime                 @default(now()) @map("created_at")
  updatedAt                 DateTime                 @updatedAt @map("updated_at")

  @@index([targetType])
  @@index([importFileId])
  @@index([containerId])
  @@index([containerLineId])
  @@index([containerDestinationId])
  @@index([palletId])
  @@index([generatedFileId])
  @@index([attendanceImportId])
  @@index([payContainerId])
  @@index([unloadingWageSettlementId])
  @@index([correctedById])
  @@index([createdAt])
  @@map("correction_feedback")
}

model OperationalSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  updatedById String?  @map("updated_by_id")
  updatedBy   User?    @relation("OperationalSettingUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull, onUpdate: Cascade)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([updatedById])
  @@map("operational_settings")
}

model AttendanceImport {
  id                 String               @id @default(cuid())
  originalFilename   String               @map("original_filename")
  storedPath         String               @map("stored_path")
  fileSha256         String               @unique @map("file_sha256")
  mimeType           String?              @map("mime_type")
  fileSizeBytes      BigInt?              @map("file_size_bytes")
  importStatus       ImportStatus         @default(UPLOADED) @map("import_status")
  parseStatus        ParseStatus          @default(NOT_PARSED) @map("parse_status")
  parserVersion      String?              @map("parser_version")
  settlementMonth    String?              @map("settlement_month")
  periodStart        DateTime?            @map("period_start") @db.Date
  periodEnd          DateTime?            @map("period_end") @db.Date
  employeeCount      Int                  @default(0) @map("employee_count")
  dayCount           Int                  @default(0) @map("day_count")
  warningCount       Int                  @default(0) @map("warning_count")
  errorCount         Int                  @default(0) @map("error_count")
  errorMessage       String?              @map("error_message")
  rawMetadata        Json?                @map("raw_metadata")
  importedById       String?              @map("imported_by_id")
  importedBy         User?                @relation("AttendanceImportImportedBy", fields: [importedById], references: [id], onDelete: SetNull, onUpdate: Cascade)
  rows               AttendanceRow[]
  generatedFiles     WageGeneratedFile[]
  correctionFeedback CorrectionFeedback[]
  createdAt          DateTime             @default(now()) @map("created_at")
  updatedAt          DateTime             @updatedAt @map("updated_at")

  @@index([parseStatus])
  @@index([settlementMonth])
  @@index([importedById])
  @@index([createdAt])
  @@map("attendance_imports")
}

model AttendanceRow {
  id                 String           @id @default(cuid())
  attendanceImportId String           @map("attendance_import_id")
  attendanceImport   AttendanceImport @relation(fields: [attendanceImportId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  rowKey             String           @map("row_key")
  employeeId         String?          @map("employee_id")
  employeeName       String?          @map("employee_name")
  department         String?
  workDate           DateTime         @map("work_date") @db.Date
  dayNumber          Int              @map("day_number")
  punchTimes         Json             @map("punch_times")
  pairedGrossHours   Decimal?         @map("paired_gross_hours") @db.Decimal(8, 2)
  lunchHours         Decimal          @default(0.5) @map("lunch_hours") @db.Decimal(8, 2)
  calculatedHours    Decimal?         @map("calculated_hours") @db.Decimal(8, 2)
  firstPunch         String?          @map("first_punch")
  lastPunch          String?          @map("last_punch")
  rawJson            Json             @map("raw_json")
  warnings           Json?
  errors             Json?
  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt @map("updated_at")

  @@unique([attendanceImportId, rowKey])
  @@index([attendanceImportId])
  @@index([employeeId])
  @@index([employeeName])
  @@index([workDate])
  @@map("attendance_rows")
}

model WageGeneratedFile {
  id                        String                   @id @default(cuid())
  attendanceImportId        String?                  @map("attendance_import_id")
  attendanceImport          AttendanceImport?        @relation(fields: [attendanceImportId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  unloadingWageSettlementId String?                  @map("unloading_wage_settlement_id")
  unloadingWageSettlement   UnloadingWageSettlement? @relation(fields: [unloadingWageSettlementId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  fileType                  WageGeneratedFileType    @map("file_type")
  storagePath               String                   @map("storage_path")
  fileSha256                String?                  @map("file_sha256")
  mimeType                  String?                  @map("mime_type")
  fileSizeBytes             BigInt?                  @map("file_size_bytes")
  status                    GeneratedFileStatus      @default(GENERATED)
  errorMessage              String?                  @map("error_message")
  generatedById             String?                  @map("generated_by_id")
  generatedBy               User?                    @relation("WageGeneratedFileGeneratedBy", fields: [generatedById], references: [id], onDelete: SetNull, onUpdate: Cascade)
  createdAt                 DateTime                 @default(now()) @map("created_at")
  updatedAt                 DateTime                 @updatedAt @map("updated_at")

  @@index([attendanceImportId])
  @@index([unloadingWageSettlementId])
  @@index([fileType])
  @@index([status])
  @@index([generatedById])
  @@index([createdAt])
  @@map("wage_generated_files")
}

model PayContainer {
  id                 String                        @id @default(cuid())
  payContainerNo     String                        @unique @map("pay_container_no")
  classification     ContainerPayClassification
  trailerNumber      String?                       @map("trailer_number")
  status             PayContainerStatus            @default(DRAFT)
  currency           String                        @default("CAD")
  rateAmount         Decimal                       @map("rate_amount") @db.Decimal(10, 2)
  allocationMethod   PayAllocationMethod           @default(EQUAL_SPLIT) @map("allocation_method")
  completedAt        DateTime?                     @map("completed_at")
  completedById      String?                       @map("completed_by_id")
  completedBy        User?                         @relation("PayContainerCompletedBy", fields: [completedById], references: [id], onDelete: SetNull, onUpdate: Cascade)
  completionNote     String?                       @map("completion_note")
  createdById        String?                       @map("created_by_id")
  createdBy          User?                         @relation("PayContainerCreatedBy", fields: [createdById], references: [id], onDelete: SetNull, onUpdate: Cascade)
  sourceContainers   PayContainerContainer[]
  unloaders          UnloaderAssignment[]
  settlementLines    UnloadingWageSettlementLine[]
  correctionFeedback CorrectionFeedback[]
  createdAt          DateTime                      @default(now()) @map("created_at")
  updatedAt          DateTime                      @updatedAt @map("updated_at")

  @@index([classification])
  @@index([trailerNumber])
  @@index([status])
  @@index([completedAt])
  @@index([completedById])
  @@index([createdById])
  @@map("pay_containers")
}

model PayContainerContainer {
  id             String       @id @default(cuid())
  payContainerId String       @map("pay_container_id")
  payContainer   PayContainer @relation(fields: [payContainerId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  containerId    String       @map("container_id")
  container      Container    @relation(fields: [containerId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  containerNo    String       @map("container_no")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  @@unique([payContainerId, containerId])
  @@unique([containerId])
  @@index([payContainerId])
  @@index([containerNo])
  @@map("pay_container_containers")
}

model UnloadingWorker {
  id                  String               @id @default(cuid())
  displayName         String               @map("display_name")
  workerCode          String               @unique @map("worker_code")
  isActive            Boolean              @default(true) @map("is_active")
  phone               String?
  note                String?
  createdById         String?              @map("created_by_id")
  createdBy           User?                @relation("UnloadingWorkerCreatedBy", fields: [createdById], references: [id], onDelete: SetNull, onUpdate: Cascade)
  updatedById         String?              @map("updated_by_id")
  updatedBy           User?                @relation("UnloadingWorkerUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull, onUpdate: Cascade)
  unloaderAssignments UnloaderAssignment[]
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @updatedAt @map("updated_at")

  @@index([isActive])
  @@index([displayName])
  @@index([createdById])
  @@index([updatedById])
  @@map("unloading_workers")
}

model UnloaderAssignment {
  id                String           @id @default(cuid())
  payContainerId    String           @map("pay_container_id")
  payContainer      PayContainer     @relation(fields: [payContainerId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  workerUserId      String?          @map("worker_user_id")
  workerUser        User?            @relation("UnloaderAssignmentUser", fields: [workerUserId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  unloadingWorkerId String?          @map("unloading_worker_id")
  unloadingWorker   UnloadingWorker? @relation(fields: [unloadingWorkerId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  workerCode        String           @map("worker_code")
  workerName        String           @map("worker_name")
  allocationAmount  Decimal?         @map("allocation_amount") @db.Decimal(10, 2)
  allocationPercent Decimal?         @map("allocation_percent") @db.Decimal(7, 4)
  note              String?
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  @@unique([payContainerId, workerCode])
  @@index([payContainerId])
  @@index([workerUserId])
  @@index([unloadingWorkerId])
  @@index([workerCode])
  @@map("unloader_assignments")
}

model UnloadingWageSettlement {
  id                 String                          @id @default(cuid())
  settlementMonth    String                          @map("settlement_month")
  currency           String                          @default("CAD")
  status             UnloadingWageSettlementStatus   @default(GENERATED)
  totalAmount        Decimal                         @default(0) @map("total_amount") @db.Decimal(12, 2)
  warningCount       Int                             @default(0) @map("warning_count")
  errorCount         Int                             @default(0) @map("error_count")
  rawJson            Json?                           @map("raw_json")
  generatedById      String?                         @map("generated_by_id")
  generatedBy        User?                           @relation("UnloadingWageSettlementGeneratedBy", fields: [generatedById], references: [id], onDelete: SetNull, onUpdate: Cascade)
  workerSummaries    UnloadingWageWorkerSettlement[]
  lines              UnloadingWageSettlementLine[]
  generatedFiles     WageGeneratedFile[]
  correctionFeedback CorrectionFeedback[]
  createdAt          DateTime                        @default(now()) @map("created_at")
  updatedAt          DateTime                        @updatedAt @map("updated_at")

  @@index([settlementMonth, status])
  @@index([settlementMonth])
  @@index([status])
  @@index([generatedById])
  @@index([createdAt])
  @@map("unloading_wage_settlements")
}

model UnloadingWageWorkerSettlement {
  id                String                        @id @default(cuid())
  settlementId      String                        @map("settlement_id")
  settlement        UnloadingWageSettlement       @relation(fields: [settlementId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  workerCode        String                        @map("worker_code")
  workerName        String                        @map("worker_name")
  payContainerCount Int                           @map("pay_container_count")
  totalAmount       Decimal                       @map("total_amount") @db.Decimal(12, 2)
  lines             UnloadingWageSettlementLine[]
  createdAt         DateTime                      @default(now()) @map("created_at")
  updatedAt         DateTime                      @updatedAt @map("updated_at")

  @@unique([settlementId, workerCode])
  @@index([settlementId])
  @@index([workerCode])
  @@map("unloading_wage_worker_settlements")
}

model UnloadingWageSettlementLine {
  id                 String                        @id @default(cuid())
  settlementId       String                        @map("settlement_id")
  settlement         UnloadingWageSettlement       @relation(fields: [settlementId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  workerSettlementId String                        @map("worker_settlement_id")
  workerSettlement   UnloadingWageWorkerSettlement @relation(fields: [workerSettlementId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  payContainerId     String?                       @map("pay_container_id")
  payContainer       PayContainer?                 @relation(fields: [payContainerId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  payContainerNo     String                        @map("pay_container_no")
  classification     ContainerPayClassification
  trailerNumber      String?                       @map("trailer_number")
  containerNumbers   Json                          @map("container_numbers")
  completedAt        DateTime                      @map("completed_at")
  rateAmount         Decimal                       @map("rate_amount") @db.Decimal(10, 2)
  allocationMethod   PayAllocationMethod           @map("allocation_method")
  workerCode         String                        @map("worker_code")
  workerName         String                        @map("worker_name")
  amount             Decimal                       @db.Decimal(12, 2)
  createdAt          DateTime                      @default(now()) @map("created_at")
  updatedAt          DateTime                      @updatedAt @map("updated_at")

  @@index([settlementId])
  @@index([workerSettlementId])
  @@index([payContainerId])
  @@index([workerCode])
  @@index([payContainerNo])
  @@map("unloading_wage_settlement_lines")
}

{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "setupFiles": ["<rootDir>/setup-e2e-env.ts"],
  "moduleNameMapper": {
    "^\\.\\./generated/prisma/client$": "<rootDir>/../src/testing/prisma-client.mock.ts"
  },
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  }
}
